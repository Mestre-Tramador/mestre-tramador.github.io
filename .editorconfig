# EditorConfig is awesome: https://EditorConfig.org

# Root file
root = true

# Optimized to UNIX like OS
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown, JSON, YAML and Lock files need usually just two spaces
[*.{md,json,yaml,yml,lock}]
indent_size = 2
